### List all repositories (REST API)
GET {{endpoint}}/rest/v2/repositories
Accept: application/json
Authorization: Bearer {{token}}

###

### List all repositories (CMIS API)
GET {{endpoint}}/browser
Accept: application/json
DataServiceVersion: 2.0
Authorization: Bearer {{token}}

###

@repository_id = 91aa8de9-4307-4ec4-b66b-c93b9b5437ab

### Get a specific repository by ID
GET {{endpoint}}/rest/v2/repositories/{{repository_id}}
Accept: application/json
Authorization: Bearer {{token}}

###

POST {{endpoint}}/rest/v2/repositories/
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "repository": {
    "displayName": "Data Archiving CI Logs Repository",
    "description": "Repository for storing CI logs from Data Archiving pipeline",
    "externalId": "",
    "repositoryType": "internal",
    "isVersionEnabled": "true",
    "isVirusScanEnabled": "true",
    "skipVirusScanForLargeFile": "false",
    "hashAlgorithms": "SHA-256",
    "isContentBridgeEnabled": true
  }
}


###

POST {{endpoint}}/rest/v2/repositories/
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "repository": {
    "displayName": "Data Archiving CI Logs Repository",
    "description": "Repository for storing CI logs from Data Archiving pipeline",
    "repositoryType": "internal",
    "repositoryId": "repocpiarchive",
    "externalId": "repocpiarchive"
  }
}
###

### Delete a repository
DELETE {{endpoint}}/rest/v2/repositories/{repository_id}
Accept: application/json
Authorization: Bearer {{token}}

###

### Test browser url
GET {{endpoint}}/browser
Accept: application/json
Authorization: Bearer {{token}}


